# Notificaciones del formulario de contacto (Vercel Function /api/contact)
# En local: copiá a .env. En Vercel: Settings → Environment Variables.

# Slack — Incoming Webhook (https://api.slack.com/messaging/webhooks)
SLACK_WEBHOOK_URL=

# Resend — email opcional (https://resend.com/api-keys)
RESEND_API_KEY=
RESEND_FROM=NIMBO <contacto@nimbodata.com>
CONTACT_NOTIFY_EMAIL=contacto@nimbodata.com

# OpenAI — chatbot con IA (solo servidor, nunca en el frontend)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
