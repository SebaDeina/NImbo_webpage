HOST=0.0.0.0
PORT=1337

# Local: sqlite (default). Render/producción: postgres + DATABASE_URL
DATABASE_CLIENT=sqlite
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgresql://user:pass@host:5432/db
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Orígenes permitidos para el frontend (separados por coma)
# CORS_ORIGINS=http://localhost:5173,https://tu-sitio.vercel.app,https://nimbodata.com

APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Resend — notificaciones del formulario de contacto
# API key: https://resend.com/api-keys
RESEND_API_KEY=
# Remitente (dominio verificado en Resend, ej: NIMBO <contacto@nimbodata.com>)
RESEND_FROM=NIMBO <contacto@nimbodata.com>
# Destino de las consultas
CONTACT_NOTIFY_EMAIL=contacto@nimbodata.com

# Slack — alertas del formulario de contacto (Incoming Webhook)
# Crear en: Slack → Apps → Incoming Webhooks → Add to Slack
SLACK_WEBHOOK_URL=
